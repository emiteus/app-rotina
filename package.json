  "type": "commonjs",
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "node-schedule": "^2.1.1",
    "pg": "^8.21.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1"
  },
  "homepage": "./",
  "build": {
    "appId": "com.approtina.app",
    "productName": "App Rotina",
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
